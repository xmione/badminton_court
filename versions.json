                            "installCommand": "$url='https://go.microsoft.com/fwlink/?linkid=2208844'; $out=\"$env:TEMP\\winsdksetup.exe\"; $wc=New-Object System.Net.WebClient; $req=[System.Net.WebRequest]::Create($url); $res=$req.GetResponse(); $total=$res.ContentLength; $res.Close(); $wc.DownloadFileAsync($url, $out); while($wc.IsBusy){ $file=Get-Item $out -ErrorAction SilentlyContinue; if($file){ $cur=$file.Length; $pct=[Math]::Round(($cur/$total)*100, 1); Write-Host \"`rDownloading: $([Math]::Round($cur/1MB, 2)) MB / $([Math]::Round($total/1MB, 2)) MB ($pct%)\" -NoNewline }; Start-Sleep -Seconds 1 }; Write-Host \"`nDownload Complete.\"; Start-Process $out -ArgumentList '/quiet /norestart /features OptionId.DesktopCPPx64 OptionId.SigningTools' -Wait; Remove-Item $out",
                            "checkCommand": "Test-Path \"C:\\Program Files (x86)\\Windows Kits\\10\\bin\\10.0.22621.0\\x64\\sn.exe\"",
